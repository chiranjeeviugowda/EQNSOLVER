        return "Error: Compositions must be between 0 and 1"
    
    if solidus_composition >= liquidus_composition:
        return "Error: Solidus composition must be less than liquidus"
    
    # Lever rule
    f_solid = (liquidus_composition - composition) / (liquidus_composition - solidus_composition)
    f_liquid = 1 - f_solid
    
    return f"Solid fraction = {f_solid:.3f}, Liquid fraction = {f_liquid:.3f}"



def hodgkin_huxley_membrane_potential(g_Na, g_K, g_L, E_Na, E_K, E_L):
