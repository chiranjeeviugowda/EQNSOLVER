    if dissipation_rate <= 0 or viscosity <= 0:
        return "Error: Parameters must be positive"
    
    # Kolmogorov scales
    eta = (viscosity**3 / dissipation_rate)**(1/4)  # length
    tau = (viscosity / dissipation_rate)**(1/2)  # time
    v_eta = (viscosity * dissipation_rate)**(1/4)  # velocity
    
    return f"η = {eta:.3e} m, τ = {tau:.3e} s, v_η = {v_eta:.3e} m/s"



def shock_wave_rankine_hugoniot(mach_number, gamma=1.4):
    """Rankine-Hugoniot relations for shock waves"""
    if mach_number <= 1:
        return "No shock wave: M ≤ 1"
    
    M = mach_number
    
    # Density ratio
    rho_ratio = ((gamma + 1) * M**2) / ((gamma - 1) * M**2 + 2)
    
    # Pressure ratio
    p_ratio = (2 * gamma * M**2 - (gamma - 1)) / (gamma + 1)
    
    # Temperature ratio
    T_ratio = p_ratio / rho_ratio
    
    return f"ρ₂/ρ₁ = {rho_ratio:.3f}, p₂/p₁ = {p_ratio:.3f}, T₂/T₁ = {T_ratio:.3f}"



def boundary_layer_thickness(reynolds_number, distance):
