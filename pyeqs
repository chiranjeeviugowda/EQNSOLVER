    elif dimension == 3:
        G = -1 / (4 * math.pi * distance)
    else:
        return "Error: Dimension must be 1, 2, or 3"
    
    return f"G({dimension}D) = {G:.6f} for r = {distance:.3e} m"



def bessel_function_zeros(order, n):
