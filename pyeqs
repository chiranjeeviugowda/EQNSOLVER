def credit_default_swap_pricing(notional, spread, recovery_rate, default_probability, discount_factor=1.0):
    """Approximate CDS valuation: expected protection leg vs premium leg (very simplified)."""
    try:
        notional = float(notional)
        spread = float(spread)
        recovery_rate = float(recovery_rate)
        default_probability = float(default_probability)
        discount_factor = float(discount_factor)
    except Exception:
        return "Error: invalid numerical inputs"
    if notional <= 0 or spread < 0:
        return "Error: Invalid notional or spread"
    if not (0 <= recovery_rate <= 1) or not (0 <= default_probability <= 1):
        return "Error: recovery_rate and default_probability must be between 0 and 1"
    # Expected protection (loss) = notional * default_prob * (1 - recovery) discounted
    expected_protection = notional * default_probability * (1 - recovery_rate) * discount_factor
    # Premium leg approximate: notional * spread * (1 - default_prob) * discount_factor
    premium_leg = notional * spread * (1 - default_probability) * discount_factor
    # Fair spread approximation
    denom = notional * (1 - default_probability) * discount_factor
    fair_spread = (expected_protection / denom) if denom != 0 else float('inf')
    return f"Expected protection = {expected_protection:.3e}, Premium leg ≈ {premium_leg:.3e}, Approx fair spread ≈ {fair_spread:.3e}"






def resolve_equation_solvers(namespace=None):
    """
    Replace 'solver' values in EQUATIONS that are strings with the actual callable
    from the provided namespace (defaults to globals()). If a solver name is not found,
    it remains as a string and a warning is recorded.
    """
    if namespace is None:
        namespace = globals()
    missing = []
    for key, val in EQUATIONS.items():
        sol = val.get('solver', None)
        if isinstance(sol, str):
            fn = namespace.get(sol, None)
            if callable(fn):
                val['solver'] = fn
            else:
                missing.append(sol)
    return missing



