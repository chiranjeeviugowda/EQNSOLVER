def fresnel_reflection_coefficients(n1, n2, angle_incident):
    """Fresnel reflection coefficients"""
    if n1 <= 0 or n2 <= 0 or angle_incident < 0:
        return "Error: Invalid parameters"
    
    theta_i = math.radians(angle_incident)
    
    # Snell's law
    theta_t = math.asin(n1 * math.sin(theta_i) / n2)
    
    # Reflection coefficients
    r_perp = (n1 * math.cos(theta_i) - n2 * math.cos(theta_t)) / (n1 * math.cos(theta_i) + n2 * math.cos(theta_t))
    r_par = (n2 * math.cos(theta_i) - n1 * math.cos(theta_t)) / (n2 * math.cos(theta_i) + n1 * math.cos(theta_t))
    
    R_perp = abs(r_perp)**2
    R_par = abs(r_par)**2
    
    return f"R_perp = {R_perp:.4f}, R_par = {R_par:.4f}, θ_t = {math.degrees(theta_t):.2f}°"



