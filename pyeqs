def dna_melting_temperature(seq_or_length, na_conc=0.05):
    """
    Approximate DNA melting temperature (Tm).
    If seq_or_length is a string (DNA sequence), use either Wallace rule (short sequences)
    or a simple empirical long-sequence formula:
      - For length < 14: Wallace rule Tm = 2*(A+T) + 4*(G+C) (°C)
      - For longer sequences: Tm = 81.5 + 0.41*(%GC) - 675/length + 16.6*log10([Na+])
    na_conc: sodium concentration in M (default 0.05 M)
    Returns Tm in degrees Celsius.
    """
    if isinstance(seq_or_length, str):
        seq = seq_or_length.upper()
        length = len(seq)
        gc = seq.count("G") + seq.count("C")
        at = seq.count("A") + seq.count("T")
        if length < 1:
            raise ValueError("Sequence length must be > 0")
        if length < 14:
            tm = 2 * at + 4 * gc
            return float(tm)
        else:
            pct_gc = 100.0 * gc / length
            tm = 81.5 + 0.41 * pct_gc - 675.0 / length + 16.6 * math.log10(max(na_conc, 1e-9))
            return float(tm)
    else:
        # assume numeric length with an average GC percent ~50%
        length = float(seq_or_length)
        pct_gc = 50.0
        tm = 81.5 + 0.41 * pct_gc - 675.0 / length + 16.6 * math.log10(max(na_conc, 1e-9))
        return float(tm)

def protein_folding_energy_landscape(delta_H, delta_S, T=298.15):
    """
    Gibbs free energy change for folding: ΔG = ΔH - T ΔS
    delta_H: enthalpy change (J/mol)
    delta_S: entropy change (J/(mol K))
    T: temperature in K (default 298.15 K)
    Returns ΔG in J/mol.
    """
    return float(delta_H) - float(T) * float(delta_S)

def cell_membrane_potential(C_out, C_in, z=1, T=298.15):
    """
    Nernst equation for equilibrium potential (in volts):
      E = (R T) / (z F) * ln([out]/[in])
    C_out/C_in: ion concentrations (same units)
    z: ion valence (default +1)
    T: temperature in Kelvin
    """
    if C_in <= 0 or C_out <= 0:
        raise ValueError("Concentrations must be positive")
    return (R_gas * T) / (z * F_const) * math.log(float(C_out) / float(C_in))

def enzyme_kinetics_competitive_inhibition(Vmax, Km, S, I=0.0, Ki=1.0):
    """
    Michaelis-Menten rate with competitive inhibitor:
      v = Vmax * [S] / (Km * (1 + [I]/Ki) + [S])
    Vmax: maximum rate
    Km: Michaelis constant
    S: substrate concentration
    I: inhibitor concentration
    Ki: inhibitor dissociation constant
    """
    denom = float(Km) * (1.0 + float(I) / float(Ki)) + float(S)
    if denom == 0:
        return 0.0
    return float(Vmax) * float(S) / denom

# Black-Scholes pricing and Greeks for European options
import math
from math import log, sqrt, exp
try:
    import mpmath as _mp
except Exception:
    _mp = None

def _norm_pdf(x):
    return math.exp(-0.5 * x * x) / math.sqrt(2.0 * math.pi)

def _norm_cdf(x):
    # use math.erf to compute normal CDF
    return 0.5 * (1.0 + math.erf(x / math.sqrt(2.0)))

def black_scholes_greeks_comprehensive(S, K, T, r, sigma, option_type='call'):
    """
    Compute Black-Scholes price and Greeks for a European call or put.
    Inputs:
      S: spot price
      K: strike
      T: time to maturity in years (if T==0 returns intrinsic values)
      r: risk-free rate (annual)
      sigma: volatility (annual)
      option_type: 'call' or 'put'
    Returns dict with price, delta, gamma, vega, theta, rho.
    """
    S = float(S); K = float(K); T = float(T); r = float(r); sigma = float(sigma)
    if T <= 0 or sigma == 0:
        # intrinsic value fallback
        if option_type.lower().startswith('c'):
            price = max(S - K, 0.0)
            delta = 1.0 if S > K else 0.0
        else:
            price = max(K - S, 0.0)
            delta = -1.0 if S < K else 0.0
        gamma = 0.0; vega = 0.0; theta = 0.0; rho = 0.0
        return {"price": price, "delta": delta, "gamma": gamma, "vega": vega, "theta": theta, "rho": rho}

    d1 = (math.log(S / K) + (r + 0.5 * sigma * sigma) * T) / (sigma * math.sqrt(T))
    d2 = d1 - sigma * math.sqrt(T)
    Nd1 = _norm_cdf(d1)
    Nd2 = _norm_cdf(d2)
    n_d1 = _norm_pdf(d1)

    if option_type.lower().startswith('c'):
        price = S * Nd1 - K * math.exp(-r * T) * Nd2
        delta = Nd1
        theta = (-S * n_d1 * sigma / (2.0 * math.sqrt(T)) - r * K * math.exp(-r * T) * Nd2)
        rho = K * T * math.exp(-r * T) * Nd2
    else:
        Nd1m = _norm_cdf(-d1)
        Nd2m = _norm_cdf(-d2)
        price = K * math.exp(-r * T) * Nd2m - S * Nd1m
        delta = -Nd1m
        theta = (-S * n_d1 * sigma / (2.0 * math.sqrt(T)) + r * K * math.exp(-r * T) * Nd2m)
        rho = -K * T * math.exp(-r * T) * Nd2m

    gamma = n_d1 / (S * sigma * math.sqrt(T))
    vega = S * n_d1 * math.sqrt(T)

    return {"price": price, "delta": delta, "gamma": gamma, "vega": vega, "theta": theta, "rho": rho}

def value_at_risk_monte_carlo(portfolio_value, mu=0.0, sigma=0.01, horizon_days=1, sims=10000, conf_level=0.95, seed=None):
    """
    Monte Carlo VaR assuming geometric Brownian motion model for portfolio returns or simple normal returns.
    portfolio_value: current portfolio value (currency)
    mu: expected daily return (decimal)
    sigma: daily volatility (decimal)
    horizon_days: days to hold
    sims: number of Monte Carlo simulations
    conf_level: e.g., 0.95 for 95% VaR
    Returns VaR (positive number indicating loss) and the returns distribution percentile.
    """
    import random
    if seed is not None:
        random.seed(seed)
    dt = float(horizon_days)
    sims = int(sims)
    losses = []
    for _ in range(sims):
        # simulate simple normal return over horizon: r ~ N(mu*dt, sigma*sqrt(dt))
        r = random.gauss(mu * dt, sigma * math.sqrt(dt))
        # end value using multiplicative model
        end = float(portfolio_value) * math.exp(r)
        loss = max(0.0, portfolio_value - end)
        losses.append(loss)
    losses.sort(reverse=True)
    idx = int((1.0 - conf_level) * sims)
    idx = min(max(idx, 0), sims - 1)
    var = losses[idx]
    return {"VaR": var, "confidence_level": conf_level, "losses_sampled": losses[:10]}

