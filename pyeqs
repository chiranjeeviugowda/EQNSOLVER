        delta = 0.16 * distance / (reynolds_number**(1/7))
        regime = "turbulent"
    
    return f"δ = {delta:.3e} m ({regime}), Re = {reynolds_number:.2e}"



def vortex_shedding_strouhal(diameter, velocity, frequency):
