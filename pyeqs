    if order == 0:
        P = 1
    elif order == 1:
        P = x
    elif order == 2:
        P = (3*x**2 - 1)/2
    else:
        # General formula would require derivative calculation
        return f"P_{order}(x) requires symbolic differentiation"
    
    return f"P_{order}({x}) = {P:.6f}"



def hermite_polynomial_quantum_oscillator(n, x):
