def critical_point_scaling(t, xi0=1.0, nu=0.63):
    """
    Correlation length scaling near a critical point:
      xi(t) = xi0 * |t|^{-nu}
    where t = (T - Tc)/Tc is reduced temperature, nu is critical exponent (default 3D Ising ~0.63).
    """
    t = float(t)
    if t == 0:
        return float('inf')
    return xi0 * abs(t) ** (-nu)

def nonlinear_optics_kerr_effect(n0, n2, intensity):
    """
    Kerr effect: refractive index change Δn = n2 * I
    Returns (n_total, delta_n)
    n0: linear refractive index
    n2: nonlinear index coefficient (m^2/W)
    intensity: optical intensity (W/m^2)
    """
    delta_n = float(n2) * float(intensity)
    return float(n0) + delta_n, delta_n

def photonic_crystal_band_gap(a, n_high, n_low):
    """
    Rough estimate of the central frequency (first bandgap) in a 1D Bragg stack:
      lambda_center ≈ 2 * a * n_avg
    central frequency f = c / lambda_center
    where a is the lattice period (m) and n_high/n_low are refractive indices of layers.
    This is an estimate for the stop-band center.
    Returns a dict with central wavelength and frequency.
    """
    n_avg = 0.5 * (float(n_high) + float(n_low))
    lambda_c = 2.0 * float(a) * n_avg
    f_c = c_light / lambda_c
    return {"lambda_center_m": lambda_c, "frequency_center_hz": f_c, "n_avg": n_avg}

def laser_threshold_condition(L, R1, R2, alpha_internal=0.0):
    """
    Laser threshold gain approximation:
      g_th = (1/(2L)) * ln(1 / (R1 * R2)) + alpha_internal
    L: cavity length (m)
    R1,R2: mirror power reflectivities (0..1)
    alpha_internal: internal loss (1/m)
    Returns threshold gain (1/m).
    """
    L = float(L)
    if L <= 0:
        raise ValueError("L must be positive")
    R1 = float(R1); R2 = float(R2)
    if not (0 < R1 <= 1 and 0 < R2 <= 1):
        raise ValueError("Mirror reflectivities must be in (0,1]")
    gth = (1.0 / (2.0 * L)) * math.log(1.0 / (R1 * R2)) + float(alpha_internal)
    return gth

def metamaterial_negative_index(eps_eff, mu_eff):
    """
    Effective refractive index n_eff = sqrt(eps_eff * mu_eff)
    Returns (n_eff, is_negative_index) where is_negative_index is True if both real parts negative.
    eps_eff, mu_eff: complex or real effective permittivity/permeability
    """
