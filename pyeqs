def black_body_spectral_radiance(wavelength, temperature):
    """Planck's law for black body radiation"""
    if wavelength <= 0 or temperature <= 0:
        return "Error: Parameters must be positive"
    
    # Planck's law
    exponent = h * c / (wavelength * k_B * temperature)
    
    if exponent > 700:  # Avoid overflow
        I_lambda = 0
    else:
        numerator = 2 * h * c**2 / wavelength**5
        denominator = math.exp(exponent) - 1
        I_lambda = numerator / denominator
    
    # Wien's displacement law peak
    lambda_max = 2.897771955e-3 / temperature
    
    return f"I(λ) = {I_lambda:.3e} W/(m³⋅sr), λ_max = {lambda_max:.3e} m"



def entropy_microcanonical(microstates):
