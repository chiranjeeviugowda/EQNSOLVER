def maxwell_relations_thermodynamics(variable_pair):
    """Maxwell relations from thermodynamics potentials"""
    relations = {
        "U": r"\left(\frac{\partial T}{\partial V}\right)_S = -\left(\frac{\partial P}{\partial S}\right)_V",
        "H": r"\left(\frac{\partial T}{\partial P}\right)_S = \left(\frac{\partial V}{\partial S}\right)_P",
        "F": r"\left(\frac{\partial S}{\partial V}\right)_T = \left(\frac{\partial P}{\partial T}\right)_V",
        "G": r"\left(\frac{\partial S}{\partial P}\right)_T = -\left(\frac{\partial V}{\partial T}\right)_P"
    }
    if variable_pair in relations:
        return f"Maxwell relation for {variable_pair}: {relations[variable_pair]}"
    else:
        return "Error: Choose from U, H, F, G (internal, enthalpy, Helmholtz, Gibbs)"


def carnot_efficiency_quantum(hot_temp, cold_temp):
