        return "Error: Invalid parameters"
    
    # Approximate zeros using asymptotic formula
    if order == 0:
        # J_0 zeros: j_{0,n} ≈ π(n - 1/4)
        zero = math.pi * (n - 0.25)
    else:
        # General asymptotic: j_{ν,n} ≈ π(n + ν/2 - 1/4)
        zero = math.pi * (n + order/2 - 0.25)
    
    return f"j_{{{order},{n}}} ≈ {zero:.6f}"



def legendre_polynomial_rodrigues(order, x):
