def schrodinger_infinite_well(n, L, mass=m_e):
    """Energy levels in infinite square well"""
    if n <= 0 or L <= 0:
        return "Error: n must be positive, L must be positive"
    
    E_n = (n**2 * math.pi**2 * hbar**2) / (2 * mass * L**2)
    k_n = n * math.pi / L
    
    return f"E_{n} = {E_n:.3e} J = {E_n/e:.6f} eV, k_{n} = {k_n:.3e} m⁻¹"



def quantum_harmonic_oscillator(n, omega, mass=m_e):
    """Quantum harmonic oscillator energy levels"""
    if n < 0:
        return "Error: n must be non-negative integer"
    
    E_n = hbar * omega * (n + 0.5)
    x_rms = math.sqrt(hbar / (2 * mass * omega))
    
    return f"E_{n} = {E_n:.3e} J = {E_n/e:.6f} eV, x_rms = {x_rms:.3e} m"



def hydrogen_atom_energy(n):
    """Hydrogen atom energy levels (Bohr model)"""
    if n < 1:
        return "Error: n must be positive integer"
    
    E_n = -13.6 / (n**2)  # in eV
    r_n = n**2 * a_0
    
    return f"E_{n} = {E_n:.6f} eV, r_{n} = {r_n:.3e} m"



def de_broglie_wavelength(mass, velocity):
    """de Broglie wavelength"""
    if mass <= 0 or velocity <= 0:
        return "Error: Mass and velocity must be positive"
    
    lambda_db = h / (mass * velocity)
    momentum = mass * velocity
    
    return f"λ = {lambda_db:.3e} m, p = {momentum:.3e} kg⋅m/s"



def heisenberg_uncertainty(delta_x, delta_p):
    """Heisenberg uncertainty principle"""
    product = delta_x * delta_p
    minimum = hbar / 2
    
    satisfies = "Satisfies" if product >= minimum else "Violates"
    return f"Δx⋅Δp = {product:.3e}, minimum = {minimum:.3e}, {satisfies} uncertainty principle"



def quantum_tunneling(E, V0, width, mass=m_e):
    """Quantum tunneling transmission probability"""
    if E >= V0:
        return "No tunneling needed - particle has enough energy"
    
    try:
        kappa = math.sqrt(2 * mass * (V0 - E)) / hbar
        T = 1 / (1 + (V0**2 * math.sinh(kappa * width)**2) / (4 * E * (V0 - E)))
        
        return f"Transmission probability T = {T:.6e} ({T*100:.4f}%)"
    except:
        return "Error in tunneling calculation"



def spin_orbital_coupling(j, l, s):
    """Spin-orbit coupling energy"""
    if abs(j - l) > s or j > l + s:
        return "Error: Invalid quantum numbers"
    
    # Simplified spin-orbit interaction
    if j == l + s:
        factor = l / 2
    elif j == abs(l - s):
        factor = -(l + 1) / 2
    else:
        factor = 0
    
    return f"Spin-orbit factor = {factor}, j = {j}, l = {l}, s = {s}"



def quantum_zeno_effect(measurement_frequency, decay_rate):
    """Quantum Zeno effect - inhibition of decay by frequent measurements"""
    if measurement_frequency <= 0 or decay_rate <= 0:
        return "Error: Parameters must be positive"
    
    # Effective decay rate with frequent measurements (standard QZE result)
    gamma_eff = decay_rate**2 / measurement_frequency
    inhibition_factor = gamma_eff / decay_rate
    
    return f"Effective decay rate = {gamma_eff:.3e} s⁻¹, inhibition = {inhibition_factor:.4f}"



def berry_phase_calculation(path_area, magnetic_flux):
    """Geometric Berry phase for adiabatic evolution"""
    if path_area <= 0:
        return "Error: Path area must be positive"
    
    # Berry phase for magnetic monopole
    berry_phase = math.pi * magnetic_flux / (h / e)  # in units of flux quantum
    
    return f"Berry phase = {berry_phase:.6f} rad = {math.degrees(berry_phase):.2f}°"



def aharonov_bohm_effect(magnetic_flux, charge=e):
    """Aharonov-Bohm phase shift"""
    flux_quantum = h / e
    phase_shift = 2 * math.pi * magnetic_flux / flux_quantum
    
    return f"Phase shift = {phase_shift:.6f} rad, Flux/Φ₀ = {magnetic_flux/flux_quantum:.4f}"



def klein_gordon_dispersion(mass, momentum):
    """Klein-Gordon energy-momentum relation"""
    E_squared = (mass * c**2)**2 + (momentum * c)**2
    E = math.sqrt(E_squared)
    
    return f"E = {E:.3e} J = {E/(m_e*c**2):.6f} mₑc²"



def dirac_spinor_energy(mass, momentum):
    """Dirac equation energy solutions"""
    E = math.sqrt((mass * c**2)**2 + (momentum * c)**2)
    
    return f"E = ±{E:.3e} J (particle and antiparticle solutions)"



def casimir_force_parallel_plates(area, separation):
    """Casimir force between parallel conducting plates"""
    if separation <= 0 or area <= 0:
        return "Error: Area and separation must be positive"
    
    force = -(math.pi**2 * hbar * c * area) / (240 * separation**4)
    pressure = force / area
    
    return f"Casimir force = {force:.3e} N, pressure = {pressure:.3e} Pa"



def lamb_shift_hydrogen_2s():
    """Lamb shift for 2S₁/₂ - 2P₁/₂ in hydrogen"""
    # Experimental value for hydrogen 2S₁/₂ - 2P₁/₂
    shift_mhz = 1057.8  # MHz
    shift_joules = shift_mhz * 1e6 * h
    
    return f"Lamb shift = {shift_mhz} MHz = {shift_joules:.3e} J = {shift_joules/e:.6f} eV"



def qed_vertex_correction():
    """QED vertex correction to electron magnetic moment"""
    # First-order QED correction
    alpha = alpha_fs
    correction = alpha / (2 * math.pi)
    
    g_factor = 2 * (1 + correction)
    anomaly = g_factor - 2
    
    return f"g-factor = {g_factor:.8f}, anomalous moment = {anomaly:.3e}"



def vacuum_polarization_correction(distance):
    """Vacuum polarization correction to Coulomb potential"""
    if distance <= 0:
        return "Error: Distance must be positive"
    
    # Leading correction at distance r
    alpha = alpha_fs
    correction = (2 * alpha) / (3 * math.pi) * math.log(1 / (distance * m_e * c / hbar))
    
    return f"Vacuum polarization correction = {correction:.6f} at r = {distance:.3e} m"



def schwinger_pair_production_threshold():
    """Critical field for Schwinger pair production"""
    E_crit = (m_e * c)**2 / (e * hbar)  # Critical electric field
    B_crit = E_crit / c  # Equivalent magnetic field
    
    return f"Critical E-field = {E_crit:.3e} V/m, Critical B-field = {B_crit:.3e} T"



def feynman_diagram_propagator(mass, momentum_squared):
    """Feynman propagator for scalar particle"""
    if mass <= 0:
        return "Error: Mass must be positive"
    
    # Scalar propagator in momentum space
    denominator = momentum_squared - (mass * c)**2
    
    if abs(denominator) < 1e-10:
        return "On-shell condition: p² = m²c²"
    
    propagator = 1 / denominator
    return f"Scalar propagator = {propagator:.3e} (GeV)⁻²"



def schwarzschild_metric_components(mass, radius):
    """Schwarzschild metric components"""
    if radius <= 0 or mass <= 0:
        return "Error: Parameters must be positive"
    
    rs = 2 * G * mass / c**2  # Schwarzschild radius
    
    if radius <= rs:
        return f"Inside event horizon! r = {radius:.3e} m < rs = {rs:.3e} m"
    
    g_tt = -(1 - rs/radius)
    g_rr = 1 / (1 - rs/radius)
    
    return f"g_tt = {g_tt:.6f}, g_rr = {g_rr:.6f}, rs = {rs:.3e} m"



def gravitational_wave_strain(mass1, mass2, distance, frequency):
    """Gravitational wave strain amplitude"""
    if any(x <= 0 for x in [mass1, mass2, distance, frequency]):
        return "Error: All parameters must be positive"
    
    # Approximate strain for circular binary
    chirp_mass = ((mass1 * mass2)**(3/5)) / ((mass1 + mass2)**(1/5))
    omega = 2 * math.pi * frequency
    
    h_0 = (4/distance) * (G * chirp_mass / c**2) * (G * chirp_mass * omega / c**3)**(2/3)
    
    return f"Strain amplitude h₀ ≈ {h_0:.3e}, chirp mass = {chirp_mass:.3e} kg"



def cosmological_redshift(scale_factor_then, scale_factor_now=1.0):
    """Cosmological redshift from scale factor"""
    if scale_factor_then <= 0:
        return "Error: Scale factor must be positive"
    
    redshift = (scale_factor_now / scale_factor_then) - 1
    
    return f"Redshift z = {redshift:.6f}, scale factor ratio = {scale_factor_now/scale_factor_then:.6f}"



def hubble_parameter_evolution(omega_m, omega_lambda, redshift):
    """Hubble parameter as function of redshift"""
    if omega_m < 0 or omega_lambda < 0:
        return "Error: Density parameters must be positive"
    
    # Friedmann equation solution
    H_H0_squared = omega_m * (1 + redshift)**3 + omega_lambda
    H_ratio = math.sqrt(H_H0_squared)
    
    return f"H(z)/H₀ = {H_ratio:.6f} at z = {redshift:.3f}"



def geodesic_deviation_equation(curvature, separation):
    """Geodesic deviation (tidal effects)"""
    if curvature == 0:
        return "No tidal effects in flat spacetime"
    
    # Simplified tidal acceleration
    tidal_accel = curvature * separation
    
    return f"Tidal acceleration = {tidal_accel:.3e} m/s²"



def black_hole_temperature(mass):
    """Hawking temperature of black hole"""
    if mass <= 0:
        return "Error: Mass must be positive"
    
    temp = hbar * c**3 / (8 * math.pi * k_B * G * mass)
    rs = 2 * G * mass / c**2
    
    return f"Hawking temperature = {temp:.3e} K, rs = {rs:.3e} m"



def wormhole_throat_radius(mass):
    """Minimum radius for traversable wormhole"""
    if mass <= 0:
        return "Error: Mass must be positive"
    
    # Approximate throat radius
    r_throat = 2 * G * mass / c**2  # Similar to Schwarzschild radius
    
    return f"Throat radius ≈ {r_throat:.3e} m"



def penrose_process_energy_extraction(mass, angular_momentum):
    """Maximum energy extraction from rotating black hole"""
    if mass <= 0:
        return "Error: Mass must be positive"
    
    # Maximum spin parameter a = J/(Mc)
    a_max = angular_momentum / (mass * c)
    
    if a_max > 1:
        return "Error: Exceeds maximum spin for black hole"
    
    # Maximum extractable energy (Penrose process)
    max_extraction = 1 - math.sqrt((1 + math.sqrt(1 - a_max**2)) / 2)
    
    return f"Max energy extraction = {max_extraction*100:.2f}% of rest mass"



def maxwell_stress_tensor(E_field, B_field):
    """Maxwell stress tensor components"""
    # Simplified: assume fields perpendicular
    energy_density = 0.5 * (epsilon_0 * E_field**2 + B_field**2 / mu_0)
    pressure = energy_density  # For electromagnetic radiation
    
    return f"Energy density = {energy_density:.3e} J/m³, radiation pressure = {pressure:.3e} Pa"



def electromagnetic_wave_impedance():
    """Impedance of free space for EM waves"""
    Z_0 = math.sqrt(mu_0 / epsilon_0)
    
    return f"Free space impedance Z₀ = {Z_0:.1f} Ω"



def cyclotron_resonance(charge, mass, B_field):
    """Cyclotron resonance frequency"""
    if mass <= 0 or B_field == 0:
        return "Error: Invalid parameters"
    
    omega_c = abs(charge * B_field) / mass
    freq_c = omega_c / (2 * math.pi)
    
    return f"Cyclotron frequency = {freq_c:.3e} Hz, ω_c = {omega_c:.3e} rad/s"



def synchrotron_radiation_power(charge, mass, acceleration, beta):
    """Power radiated by relativistic accelerating charge"""
    if mass <= 0 or beta >= 1:
        return "Error: Invalid parameters"
    
    gamma = 1 / math.sqrt(1 - beta**2)
    
    # Larmor formula with relativistic correction
    P_classical = (charge**2 * acceleration**2) / (6 * math.pi * epsilon_0 * c**3)
    P_relativistic = P_classical * gamma**6
    
    return f"Synchrotron power = {P_relativistic:.3e} W (γ = {gamma:.3f})"



def plasma_dispersion_relation(omega, omega_p, k, v_th):
    """Plasma wave dispersion relation"""
    if omega_p <= 0:
        return "Error: Plasma frequency must be positive"
    
    # Simplified cold plasma approximation
    if omega < omega_p:
        return "Evanescent wave - frequency below plasma cutoff"
    
    # Wave vector for electromagnetic wave in plasma
    k_wave = (omega / c) * math.sqrt(1 - (omega_p / omega)**2)
    
    return f"Wave vector k = {k_wave:.3e} m⁻¹, phase velocity = {omega/k_wave/c:.6f}c"



def magnetic_reconnection_rate(B_field, density, resistivity):
    """Magnetic reconnection rate (Sweet-Parker model)"""
    if any(x <= 0 for x in [B_field, density, resistivity]):
        return "Error: Parameters must be positive"
    
    # Alfvén velocity
    v_A = B_field / math.sqrt(mu_0 * density * m_p)  # Assuming protons
    
    # Sweet-Parker reconnection rate
    S = mu_0 * v_A / resistivity  # Lundquist number (simplified)
    reconnection_rate = v_A / math.sqrt(S)
    
    return f"Reconnection rate ≈ {reconnection_rate:.3e} m/s, Alfvén velocity = {v_A:.3e} m/s"



def cherenkov_radiation_threshold(particle_velocity, refractive_index):
    """Cherenkov radiation threshold and angle"""
    if refractive_index <= 1:
        return "Error: Refractive index must be > 1"
    
    threshold_velocity = c / refractive_index
    beta = particle_velocity / c
    beta_threshold = 1 / refractive_index
    
    if beta < beta_threshold:
        return f"Below threshold: v = {particle_velocity:.3e} m/s < {threshold_velocity:.3e} m/s"
    
    cos_theta = 1 / (refractive_index * beta)
    theta = math.degrees(math.acos(cos_theta))
    
    return f"Cherenkov angle = {theta:.2f}°, threshold velocity = {threshold_velocity:.3e} m/s"



def bloch_electron_effective_mass(band_curvature):
    """Effective mass of electrons in crystal"""
    if band_curvature == 0:
        return "Error: Band curvature cannot be zero"
    
    m_eff = hbar**2 / band_curvature
    
    return f"Effective mass = {m_eff:.3e} kg = {m_eff/m_e:.3f} mₑ"



def cooper_pair_coherence_length(fermi_velocity, energy_gap):
    """BCS coherence length"""
    if fermi_velocity <= 0 or energy_gap <= 0:
        return "Error: Parameters must be positive"
    
    xi = hbar * fermi_velocity / (math.pi * energy_gap)
    
    return f"Coherence length ξ = {xi:.3e} m"



def josephson_junction_critical_current(energy_gap, resistance):
    """Critical current in Josephson junction"""
    if energy_gap <= 0 or resistance <= 0:
        return "Error: Parameters must be positive"
    
    I_c = (math.pi * energy_gap) / (2 * e * resistance)
    
    return f"Critical current Ic = {I_c:.3e} A"



def quantum_hall_conductivity(filling_factor):
    """Quantum Hall conductivity"""
    conductivity_quantum = e**2 / h
    sigma_xy = filling_factor * conductivity_quantum
    
    return f"σxy = {sigma_xy:.3e} S, ν = {filling_factor}"



def anderson_localization_length(disorder_strength, dimension):
    """Localization length in disordered systems"""
    if disorder_strength <= 0:
        return "Error: Disorder strength must be positive"
    
    # Simplified estimate
    if dimension <= 2:
        xi = hbar / disorder_strength  # Always localized in 1D, 2D
    else:
        xi = (hbar / disorder_strength) * (1 / disorder_strength)  # 3D case
    
    return f"Localization length ξ ≈ {xi:.3e} m (d = {dimension})"



def fermi_liquid_specific_heat(temperature, fermi_temperature):
    """Fermi liquid electronic specific heat"""
    if temperature <= 0 or fermi_temperature <= 0:
        return "Error: Temperatures must be positive"
    
    # Linear in T for Fermi liquids
    gamma = (math.pi**2 * k_B**2) / (3 * k_B * fermi_temperature)  # Sommerfeld coefficient
    C_el = gamma * temperature
    
    return f"Electronic specific heat = {C_el:.3e} J/(mol⋅K), γ = {gamma:.3e}"



def kondo_temperature(exchange_coupling, density_of_states):
    """Kondo temperature for magnetic impurity"""
    if exchange_coupling <= 0 or density_of_states <= 0:
        return "Error: Parameters must be positive"
    
    # Kondo temperature estimate
    T_K = math.exp(-1 / (exchange_coupling * density_of_states))
    
    return f"Kondo temperature TK ≈ {T_K:.3e} K"



def mott_insulator_gap(coulomb_repulsion, bandwidth):
    """Mott-Hubbard insulating gap"""
    if coulomb_repulsion <= 0 or bandwidth <= 0:
        return "Error: Parameters must be positive"
    
    # Simplified Mott criterion
    if coulomb_repulsion > bandwidth:
        gap = coulomb_repulsion - bandwidth
        return f"Mott insulator with gap Δ ≈ {gap:.3e} eV"
    else:
        return "Metallic state: U < W (Coulomb < bandwidth)"



def nuclear_binding_energy_semf(A, Z):
    """Semi-empirical mass formula binding energy"""
    if A <= 0 or Z < 0 or Z > A:
        return "Error: Invalid nucleon/proton numbers"
    
    N = A - Z
    
    # SEMF coefficients (MeV)
    a_v = 15.75  # volume
    a_s = 17.8   # surface  
    a_c = 0.711  # Coulomb
    a_a = 23.7   # asymmetry
    
    # Pairing term
    if N % 2 == 0 and Z % 2 == 0:
        delta = 11.18 / math.sqrt(A)
    elif N % 2 == 1 and Z % 2 == 1:
        delta = -11.18 / math.sqrt(A)
    else:
        delta = 0
    
    # Total binding energy
    BE = (a_v * A - a_s * A**(2/3) - a_c * Z**2 / A**(1/3) 
          - a_a * (N - Z)**2 / A + delta)
    
    return f"BE = {BE:.1f} MeV, BE/A = {BE/A:.3f} MeV/nucleon"



def radioactive_decay_chain(N0, lambda1, lambda2, time):
    """Two-step decay chain N1 → N2 → N3"""
    if any(x <= 0 for x in [N0, lambda1, lambda2, time]):
        return "Error: Parameters must be positive"
    
    # Parent nucleus
    N1 = N0 * math.exp(-lambda1 * time)
    
    # Daughter nucleus  
    if abs(lambda1 - lambda2) > 1e-10:
        N2 = (N0 * lambda1 / (lambda2 - lambda1)) * (math.exp(-lambda1 * time) - math.exp(-lambda2 * time))
    else:
        N2 = N0 * lambda1 * time * math.exp(-lambda1 * time)  # Equal decay constants
    
    # Granddaughter
    N3 = N0 - N1 - N2
    
    return f"N1 = {N1:.3e}, N2 = {N2:.3e}, N3 = {N3:.3e} at t = {time:.2f}s"



def cross_section_breit_wigner(energy, resonance_energy, width):
    """Breit-Wigner resonance cross section"""
    if width <= 0:
        return "Error: Width must be positive"
    
    # Breit-Wigner formula
    denominator = (energy - resonance_energy)**2 + (width/2)**2
    sigma = (math.pi * width**2) / (4 * denominator)
    
    return f"Cross section = {sigma:.3e} barn at E = {energy:.3f} MeV"



def nuclear_fission_fragments(A_parent, Z_parent):
    """Typical fission fragment distribution"""
    if A_parent < 200 or Z_parent < 80:
        return "Error: Nucleus too light for typical fission"
    
    # Asymmetric fission (most probable)
    A_light = int(A_parent * 0.4)
    A_heavy = A_parent - A_light
    
    # Approximate charge distribution
    Z_light = int(Z_parent * A_light / A_parent)
    Z_heavy = Z_parent - Z_light
    
    # Energy release (typical)
    Q_value = 200  # MeV for U-235 fission
    
    return f"Fragments: A_light={A_light}, Z_light={Z_light}; A_heavy={A_heavy}, Z_heavy={Z_heavy}; Q≈{Q_value} MeV"



def neutron_flux_diffusion(diffusion_coeff, absorption_cross_section, source_strength):
    """Neutron diffusion equation solution"""
    if any(x <= 0 for x in [diffusion_coeff, absorption_cross_section]):
        return "Error: Parameters must be positive"
    
    # Diffusion length
    L_diff = math.sqrt(diffusion_coeff / absorption_cross_section)
    
    # Critical size for sphere
    R_crit = math.pi * L_diff
    
    return f"Diffusion length = {L_diff:.3e} m, critical radius ≈ {R_crit:.3e} m"



def quark_confinement_potential(separation):
    """Linear confinement potential between quarks"""
    if separation <= 0:
        return "Error: Separation must be positive"
    
    # String tension (approximate)
    sigma = 1.0  # GeV/fm
    
    # Linear potential
    V_conf = sigma * separation * 1e15  # Convert to GeV
    
    return f"Confinement potential ≈ {V_conf:.3f} GeV at r = {separation:.3e} m"



def standard_model_running_coupling(energy, coupling_const, beta_coefficient):
    """Running of coupling constants in Standard Model"""
    if energy <= 0:
        return "Error: Energy must be positive"
    
    # One-loop beta function
    energy_ref = 91.2  # GeV (Z boson mass)
    log_ratio = math.log(energy / energy_ref)
    
    alpha_running = coupling_const / (1 + beta_coefficient * coupling_const * log_ratio / (2 * math.pi))
    
    return f"α({energy:.1f} GeV) = {alpha_running:.6f}, β₀ = {beta_coefficient}"



def partition_function_ising_1d(N, coupling, temperature):
    """1D Ising model partition function"""
    if N <= 0 or temperature <= 0:
        return "Error: Parameters must be positive"
    
    # Transfer matrix eigenvalues
    lambda_1 = math.exp(coupling / (k_B * temperature)) + math.exp(-coupling / (k_B * temperature))
    lambda_2 = math.exp(coupling / (k_B * temperature)) - math.exp(-coupling / (k_B * temperature))
    
    # Partition function
    Z = lambda_1**N + lambda_2**N
    
    # Free energy per spin
    f = -(k_B * temperature / N) * math.log(Z)
    
    return f"Z = {Z:.3e}, free energy per spin = {f:.3e} J"



def critical_exponents_ising_2d():
    """Exact critical exponents for 2D Ising model"""
    alpha = 0  # specific heat
    beta = 1/8  # magnetization
    gamma = 7/4  # susceptibility
    delta = 15  # critical isotherm
    nu = 1  # correlation length
    eta = 1/4  # correlation function
    
    return f"α={alpha}, β={beta}, γ={gamma}, δ={delta}, ν={nu}, η={eta}"



def landau_theory_phase_transition(temperature, critical_temp, order_parameter):
    """Landau theory of phase transitions"""
    if critical_temp <= 0:
        return "Error: Critical temperature must be positive"
    
    reduced_temp = (temperature - critical_temp) / critical_temp
    
    if temperature > critical_temp:
        # Disordered phase
        m_eq = 0
        susceptibility = 1 / (2 * reduced_temp)
    else:
        # Ordered phase
        m_eq = math.sqrt(-reduced_temp) if reduced_temp < 0 else 0
        susceptibility = 1 / (4 * abs(reduced_temp)) if reduced_temp != 0 else float('inf')
    
    return f"Order parameter = {m_eq:.4f}, susceptibility = {susceptibility:.3f}"



def monte_carlo_acceptance_probability(energy_diff, temperature):
    """Metropolis algorithm acceptance probability"""
    if temperature <= 0:
        return "Error: Temperature must be positive"
    
    if energy_diff <= 0:
        prob = 1.0  # Always accept lower energy
    else:
        prob = math.exp(-energy_diff / (k_B * temperature))
    
    return f"Acceptance probability = {prob:.6f}"



def renormalization_group_flow(coupling, beta_function):
    """RG flow of coupling constant"""
    # Simple beta function example
