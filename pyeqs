    if hot_temp <= cold_temp or cold_temp <= 0:
        return "Error: Invalid temperatures"
    
    # Classical Carnot efficiency
    eta_classical = 1 - cold_temp / hot_temp
    
    # Quantum correction (simplified)
    if hot_temp < 1:  # Quantum regime (normalized units)
        correction = math.exp(-1/hot_temp)
        eta_quantum = eta_classical * (1 - correction)
    else:
        eta_quantum = eta_classical
    
    return f"η_classical = {eta_classical:.4f}, η_quantum = {eta_quantum:.4f}"



def phase_transition_latent_heat(transition_temp, volume_change, pressure_change):
